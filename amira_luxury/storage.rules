rules_version = '2';

// Amira Luxury — Cloud Storage rules.
//
// Product / portfolio images are public-read so the app can load them via plain
// URLs (NetworkImage sends no auth). Only admins may upload or delete.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
