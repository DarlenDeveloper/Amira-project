rules_version = '2';

// Amira Luxury — Cloud Storage rules.
service firebase.storage {
  match /b/{bucket}/o {

    // Visual Studio: one room photo per session folder (create-only, no overwrite).
    match /visual-studio/{uid}/{renderId}/{fileName} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.admin == true);
      allow create: if request.auth != null
        && request.auth.uid == uid
        && fileName == 'room.jpg'
        && request.resource.size < 30 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow update: if false;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // AI Agent attachments (future).
    match /ai-agent/{uid}/{conversationId}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.admin == true);
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 30 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Legacy renders path — KEEP for Play Store builds still uploading here
    // (renders/{uid}/room_*.jpg). Do not remove until all users are on the
    // visual-studio path. New app versions use visual-studio/ below.
    match /renders/{uid}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Product / portfolio images: public read, admin write.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
