rules_version = '2';

// Amira Luxury — Cloud Storage rules.
//
// Product / portfolio images are public-read so the app can load them via plain
// URLs (NetworkImage sends no auth). Only admins may upload or delete.
service firebase.storage {
  match /b/{bucket}/o {

    // Room photos / AI renders: a user manages only their own folder. Read is
    // owner-or-admin (in-app display uses tokenised download URLs anyway).
    match /renders/{uid}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Everything else (product / portfolio images): public read, admin write.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
