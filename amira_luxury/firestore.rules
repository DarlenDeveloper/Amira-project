rules_version = '2';

// Amira Luxury — Firestore security rules.
//
// Baseline policy: deny everything, then explicitly allow the few things a
// signed-in user is permitted to do. As new collections come online (designs,
// products, orders, etc.) add narrowly-scoped rules below rather than loosening
// these.
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ───────────────────────────────────────────────────────────────
    // A user may read and write only their own profile document. The uid in the
    // path must match the authenticated uid.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidProfile();
      allow update: if isOwner(uid) && isValidProfile();
      allow delete: if false; // profiles are not user-deletable for now

      // Future: user-scoped subcollections (e.g. cart, favourites) inherit the
      // owner check by default.
      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Guards profile writes: only known fields, with the right types. Keeps a
    // compromised client from stuffing arbitrary data into the doc.
    function isValidProfile() {
      let allowed = ['name', 'email', 'phone', 'address', 'photoUrl',
                     'createdAt', 'updatedAt'];
      let data = request.resource.data;
      return data.keys().hasOnly(allowed)
        && (!('name' in data) || data.name is string)
        && (!('email' in data) || data.email is string)
        && (!('phone' in data) || data.phone is string)
        && (!('address' in data) || data.address is string)
        && (!('photoUrl' in data) || data.photoUrl is string);
    }

    // Everything not matched above is denied by default.
  }
}
