rules_version = '2';

// Amira Luxury — Firestore security rules.
//
// Baseline policy: deny everything, then explicitly allow the few things a
// signed-in user is permitted to do. As new collections come online (designs,
// products, orders, etc.) add narrowly-scoped rules below rather than loosening
// these.
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ───────────────────────────────────────────────────────────────
    // A user may read and write only their own profile document. The uid in the
    // path must match the authenticated uid.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidProfile();
      allow update: if isOwner(uid) && isValidProfile();
      allow delete: if false;

      // Render history mirror — Functions write; owner + admin read.
      match /renders/{renderId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if false;
      }

      match /cart/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /favourites/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /notificationState/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Visual Studio renders (top-level audit trail) ─────────────────────────
    // Written by Cloud Functions only (Admin SDK).
    match /renders/{renderId} {
      allow read: if isOwnerOf(resource) || isAdmin();
      allow create, update, delete: if false;
    }

    // ── Products (catalogue) ─────────────────────────────────────────────────
    // Admin-authored. Any signed-in user may read; only an admin may write.
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.admin == true;
    }

    // ── Portfolio (showcase projects) ─────────────────────────────────────────
    // Admin-authored. Any signed-in user may read; only an admin may write.
    match /portfolio/{portfolioId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Orders ───────────────────────────────────────────────────────────────
    // A user creates and reads only their own orders. Admins read all and may
    // update (e.g. advance status). The owner uid is fixed at create time.
    match /orders/{orderId} {
      allow read: if isOwnerOf(resource) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Appointments ──────────────────────────────────────────────────────────
    match /appointments/{appointmentId} {
      allow read: if isOwnerOf(resource) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Conversations (AI agent threads) ──────────────────────────────────────
    // User owns their threads; admin reviews all. Messages live in a
    // subcollection. (App-side conversation writes come in a later phase.)
    match /conversations/{conversationId} {
      allow read: if isOwnerOf(resource) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isOwnerOf(resource) || isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn();
        // Customers may add their own turns; only an admin may post as the
        // Amira team. Prevents a client from impersonating an admin reply.
        allow create: if isSignedIn()
          && (request.resource.data.from != 'admin' || isAdmin());
        allow update, delete: if isAdmin();
      }
    }

    // ── Notifications (admin broadcasts) ──────────────────────────────────────
    // Public read — guests on web/app can see broadcast announcements.
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Config (admin-tuned settings, e.g. the AI agent) ──────────────────────
    // Signed-in clients read (the app needs the agent's greeting / on-off);
    // only an admin writes.
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // OTP codes for password reset — Cloud Functions only (Admin SDK).
    match /password_reset_otps/{docId} {
      allow read, write: if false;
    }

    // ── Page / product views (web shop analytics) ───────────────────────────
    match /pageViews/{eventId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && isValidPageView();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Doc-level owner check for collections that carry a `uid` field.
    function isOwnerOf(res) {
      return isSignedIn() && res.data.uid == request.auth.uid;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Guards profile writes: only known fields, with the right types. Keeps a
    // compromised client from stuffing arbitrary data into the doc.
    function isValidProfile() {
      let allowed = ['name', 'email', 'phone', 'address', 'photoUrl',
                     'createdAt', 'updatedAt'];
      let data = request.resource.data;
      return data.keys().hasOnly(allowed)
        && (!('name' in data) || data.name is string)
        && (!('email' in data) || data.email is string)
        && (!('phone' in data) || data.phone is string)
        && (!('address' in data) || data.address is string)
        && (!('photoUrl' in data) || data.photoUrl is string);
    }

    function isValidPageView() {
      let data = request.resource.data;
      let allowed = ['uid', 'isGuest', 'source', 'page', 'productId',
                     'productName', 'category', 'createdAt'];
      return data.keys().hasOnly(allowed)
        && data.uid is string
        && data.isGuest is bool
        && data.source is string
        && data.page is string
        && (!('productId' in data) || data.productId is string)
        && (!('productName' in data) || data.productName is string)
        && (!('category' in data) || data.category is string);
    }

    // Everything not matched above is denied by default.
  }
}
