# Optional Firebase web config overrides for the Explore web shop.
# Copy to .env and fill in if you register a dedicated Web app in the
# Firebase console. Defaults in src/firebase.js target the amira-interiors project.
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
